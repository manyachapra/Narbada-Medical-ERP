{
  "name": "winlife",
  "version": "1.0.0",
  "description": "Winlife Pharmacy Manager",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "backend": "npm --prefix backend start",
    "dev:db": "concurrently \"npm run backend\" \"npm run dev\"",
    "electron": "wait-on tcp:5173 && electron .",
    "dev:all": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "electron": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "wait-on": "^8.0.3"
  }
}
